.vscode/
.DS_Store
compile_commands.json
.clangd
.cache/

# Legacy / internal
old/
.claude/


# Python
__pycache__/
*.pyc
*.egg-info/
venv/
.venv/

# Toolchain (built locally via `apatchy setup`)
framework/toolchain/
grammar_mutator/

# Downloaded Apache source inside project dir
framework/httpd-*/

# Build artifacts
*.o
*.lo
*.la
*.so
.libs/
.objects/

# Compiled harness binaries (fuzz_harness_afl, fuzz_harness_standalone, etc.)
