# Fuzzer runtime directories
fuzz-output/
afl-output/
libfuzzer-output/
afl-pwn-*/
afl-cov-report-*/

# Generated bug seeds (created by `apatchy bug setup`)
framework/bugs/*/seeds/

# Generated grammar seeds (created by `apatchy fuzz --grammar`)
framework/fuzz-seeds/grammar_*.txt
framework/afl-input/

# Built external modules (created by `apatchy module build`)
framework/modules/

# Runtime Apache config files (generated by build)
framework/conf/
# ... but track mime.types (needed by all httpd configs)
!framework/conf/mime.types

# Debug / configure logs
*.log

# Generated config (machine-specific paths)
toolchain.config

# Coverage data
*.profraw
*.profdata
coverage-report*/
cov-*/
.coverage

# Callgrind profiling output
callgrind-out/

# Pytest
.pytest_cache/
.test_cache/

# Dev harness projects (user-specific, created by `apatchy dev init`)
framework/dev/

# Copied harness sources (build artifacts from `apatchy link`)
/fuzz_harness.c
framework/fuzz_harness.c
framework/fuzz_common.c
framework/fuzz_common.h
framework/out-*
framework/afl-out-*
out-*.txt

