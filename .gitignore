# Debug / configure logs
*.log

# Generated config (machine-specific paths)
toolchain.config

# Coverage data
*.profraw
*.profdata
coverage-report*/
cov-*/

# Dev harness projects (user-specific, created by `fuzzer dev init`)
apache_fuzzer/dev/

# Copied harness source in working dir root
/fuzz_harness.c
apache_fuzzer/out-*
apache_fuzzer/afl-out-*
out-*.txt

# Sphinx build output
docs/api/_build/

# Obsidian vault config
docs/.obsidian/

