method: AJP_POST
uri: "/"
headers { name: "Host" value: "localhost" }
headers { name: "Content-Type" value: "application/x-www-form-urlencoded" }
req_body: "foo=bar"
resp {
  send_headers {
    status: AJP_OK_200
    status_msg: "OK"
    headers { code: AJP_HDR_CONTENT_TYPE value: "text/plain" }
  }
  body_chunks { data: "ok" }
  reuse: true
}
